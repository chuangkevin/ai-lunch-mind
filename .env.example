# AI 午餐推薦系統環境變數配置範本
# 複製此檔案為 .env 並填入實際的 API Key

# ===========================================
# API Keys - 必須設定
# ===========================================

# OpenAI API Key (用於 AI 對話和推薦)
# 申請地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Maps API Key (用於餐廳搜索和地圖服務)
# 申請地址: https://console.cloud.google.com/apis/credentials
# 需要啟用: Places API (New), Maps JavaScript API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 中央氣象署 API Key (用於台灣天氣資料)
# 申請地址: https://opendata.cwb.gov.tw/user/authkey
CWB_API_KEY=your_cwb_api_key_here

# ===========================================
# 資料庫配置
# ===========================================

# 資料庫連接字串 (預設使用 SQLite)
DATABASE_URL=sqlite:///./ai_lunch_mind.db

# ===========================================
# 應用程式配置
# ===========================================

# 除錯模式 (開發時設為 true，正式環境設為 false)
DEBUG=true

# 伺服器主機位址
HOST=0.0.0.0

# 伺服器連接埠
PORT=8000

# ===========================================
# AI 模型配置
# ===========================================

# AI 回應最大 token 數
MAX_TOKENS=1000

# AI 創意度 (0.0-1.0，數值越高越有創意)
TEMPERATURE=0.7

# ===========================================
# 搜尋配置
# ===========================================

# 餐廳搜尋半徑 (公尺)
SEARCH_RADIUS=500

# 最大搜尋餐廳數量
MAX_RESTAURANTS=20
